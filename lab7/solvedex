#include <stdio.h>
#include <stdlib.h>  // Needed for malloc()

typedef struct node {
    int info;
    struct node *left, *right;
} NODE;

NODE* create(NODE *bnode, int x) {
    if (bnode == NULL) {
        bnode = (NODE*)malloc(sizeof(NODE));
        bnode->info = x;
        bnode->left = bnode->right = NULL;
    }
    else if (x > bnode->info)
        bnode->right = create(bnode->right, x);
    else if (x < bnode->info)
        bnode->left = create(bnode->left, x);
    return bnode;
}

void inorder(NODE *ptr) {
    if (ptr != NULL) {
        inorder(ptr->left);
        printf("%d ", ptr->info);
        inorder(ptr->right);
    }
}

void postorder(NODE *ptr) {
    if (ptr != NULL) {
        postorder(ptr->left);
        postorder(ptr->right);
        printf("%d ", ptr->info);
    }
}

void preorder(NODE *ptr) {
    if (ptr != NULL) {
        printf("%d ", ptr->info);
        preorder(ptr->left);
        preorder(ptr->right);
    }
}

int main() {
    int x, ch;
    NODE *root = NULL;

    while (1) {
        printf("\n--- Menu ---\n");
        printf("1. Insert Node\n");
        printf("2. Display Traversals\n");
        printf("3. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &ch);

        switch (ch) {
        case 1:
            printf("Enter the node (no duplicates): ");
            scanf("%d", &x);
            root = create(root, x);
            break;
        case 2:
            printf("\nInorder traversal: ");
            inorder(root);
            printf("\nPreorder traversal: ");
            preorder(root);
            printf("\nPostorder traversal: ");
            postorder(root);
            printf("\n");
            break;
        case 3:
            return 0;
        default:
            printf("Invalid choice!\n");
        }
    }
}
